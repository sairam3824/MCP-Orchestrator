{
  "name": "mcp-orchestrator",
  "version": "0.1.0",
  "description": "Meta MCP server for routing, load balancing, and monitoring downstream MCP servers",
  "type": "module",
  "main": "dist/src/index.js",
  "bin": {
    "mcp-orch": "dist/src/cli.js",
    "mcp-orchestrator": "dist/src/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "dev": "tsx src/cli.ts start",
    "start": "node dist/src/cli.js start"
  },
  "keywords": [
    "mcp",
    "orchestrator",
    "router",
    "load-balancer",
    "monitoring"
